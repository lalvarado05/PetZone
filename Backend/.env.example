# Copien este formato a su archivo .env y llénelo con sus valores reales
# Nunca suban las credenciales reales a un repositorio público.

MONGODB_URI="mongodb://<username>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/?ssl=true&replicaSet=<replica-set>&authSource=admin&appName=<app-name>"
JWT_SECRET="yo_se_las_paso"
